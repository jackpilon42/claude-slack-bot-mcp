SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
# Optional: this bot's Slack user id (U… from the **bot**, not your personal user). Wrong value drops your messages.
# If unset, the bot fills it from auth.test on startup.
# SLACK_BOT_USER_ID=U0123456789
#
# Local signed test: npm run start, then npm run slack:ping-local (needs SLACK_TEST_CHANNEL=C… for a channel the bot is in).
# SLACK_TEST_CHANNEL=C0123456789
# SLACK_EVENTS_URL=http://127.0.0.1:3000/slack/events
# Milliseconds before the bot posts “still working…” in the same thread (default 5000).
# SLACK_SLOW_WORK_HINT_MS=5000
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-proj-your-openai-key-here
SMARTSHEET_API_TOKEN=your-smartsheet-api-token-here
SMARTSHEET_SHEET_ID=your-sheet-id-here
#
# --- Optional: Smartsheet hosted MCP (this repo branch only) ---
# When set to 1, plain-English Smartsheet edits use Smartsheet's MCP + Claude tool loop instead of in-bot parsers.
# Revert anytime: unset or set to 0 and use the original claude-slack-bot project unchanged.
# SMARTSHEET_USE_OFFICIAL_MCP=1
# US default; use EU/AU URLs if your Smartsheet account is in those regions (see Smartsheet MCP install docs).
# SMARTSHEET_MCP_URL=https://mcp.smartsheet.com
# Optional overrides:
# SMARTSHEET_MCP_CLAUDE_MODEL=claude-sonnet-4-20250514
# SMARTSHEET_MCP_MAX_TOOL_ROUNDS=12
AUTODESK_CLIENT_ID=your-autodesk-client-id-here
AUTODESK_CLIENT_SECRET=your-autodesk-client-secret-here
# Public URL for this bot, used for Autodesk OAuth callback route:
# /autodesk/callback
PUBLIC_BASE_URL=https://your-ngrok-or-domain.example
# Optional explicit override (if set, takes precedence over PUBLIC_BASE_URL):
# AUTODESK_REDIRECT_URI=https://your-ngrok-or-domain.example/autodesk/callback
# Optional scopes for Autodesk OAuth (3-legged).
# For BuildingConnected reads, start with data:read and add others only if needed.
AUTODESK_SCOPES=data:read
# After `bc connect`, OAuth tokens are persisted to `.autodesk-tokens.json` (gitignored) so restarts keep the session.
# AUTODESK_TOKEN_STORE_PATH=/custom/secure/path/autodesk-tokens.json
# Optional JSON map of friendly names -> sheet ids (plain English: "In Job Sim sheet, …" / "Switch to Ops sheet").
# SMARTSHEET_SHEET_MAP={"Job Sim":"SHEET_ID_1","Ops tracker":"SHEET_ID_2"}
#
# --- BuildingConnected (disabled in this bot build: API only, no Playwright / UI scrape) ---
# If BC_WEB_FALLBACK_ENABLED=1 is still set, the bot ignores it and logs a warning at startup.
# (Legacy vars below are unused while bc-web-fallback.js has BC_WEB_FALLBACK_DISABLED.)
# BC_WEB_STORAGE_STATE_PATH=playwright/.bc-storage-state.json
# BC_WEB_START_URL=https://app.buildingconnected.com/bid-board
# BC_WEB_FALLBACK_URLS=https://a.example/b,https://b.example/c
# BC_WEB_HEADFUL=1
#
# Public Bid Tracker (California open bids HTML — no API key)
# PUBLIC_BID_TRACKER_URL=https://publicbidtracker.com/california/open-bids/
# PUBLIC_BID_TRACKER_TIMEOUT_MS=60000
# PUBLIC_BIDS_MAX_RESULTS=20
